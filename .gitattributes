# Normalize line endings: store LF in the repo, check out LF everywhere.
# Keeps gofmt/golangci-lint consistent across Windows and Linux/CI.
* text=auto eol=lf

*.go   text eol=lf
*.mod  text eol=lf
*.sum  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sql  text eol=lf
*.md   text eol=lf
*.sh   text eol=lf

# Binary assets (never normalize).
*.png binary
*.jpg binary
*.gif binary
*.ico binary
